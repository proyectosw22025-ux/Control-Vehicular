# ── Django ─────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DJANGO_SETTINGS_MODULE=config.settings.production

# Hosts permitidos separados por coma (sin espacios al inicio/fin)
# Ejemplo: ALLOWED_HOSTS=mi-app.up.railway.app,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# Orígenes CORS permitidos (URL del frontend)
# Ejemplo: CORS_ALLOWED_ORIGINS=https://mi-frontend.vercel.app,http://localhost
CORS_ALLOWED_ORIGINS=http://localhost

# ── Base de datos PostgreSQL ───────────────────────────────────
DB_NAME=control_vehicular
DB_USER=postgres
DB_PASSWORD=cambia-esto-por-una-password-segura
DB_HOST=db
DB_PORT=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email SMTP ─────────────────────────────────────────────────
# Para Gmail: activar "Contraseñas de aplicación" en la cuenta Google
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-password-de-aplicacion
DEFAULT_FROM_EMAIL=Parqueo UAGRM <noreply@uagrm.edu.bo>

# ── Sentry (opcional — monitoreo de errores) ───────────────────
# Obtener el DSN en sentry.io al crear el proyecto
# Backend
SENTRY_DSN=
# Frontend (en Vercel se configura como variable de entorno VITE_SENTRY_DSN)
VITE_SENTRY_DSN=
